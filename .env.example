# Backend
SECRET_KEY=change-me-in-production
DATABASE_URL=sqlite:///./recipe_app.db
ACCESS_TOKEN_EXPIRE_MINUTES=60

# OpenAI (for recipe translation and adaptation)
OPENAI_API_KEY=

# Resend (for all outgoing email; required for verification + shopping list emails)
# On Railway: set RESEND_API_KEY, RESEND_FROM_EMAIL, and FRONTEND_URL to your Vercel app URL
RESEND_API_KEY=
RESEND_FROM_EMAIL=
FRONTEND_URL=http://localhost:5173

# Admin token for privileged operations
ADMIN_TOKEN=

# Turnstile (optional; if set, registration requires valid captcha)
# Frontend: set VITE_TURNSTILE_SITE_KEY in your frontend env (e.g. Vercel)
TURNSTILE_SECRET_KEY=
