# Backend
SECRET_KEY=change-me-in-production
DATABASE_URL=sqlite:///./recipe_app.db
ACCESS_TOKEN_EXPIRE_MINUTES=60

# OpenAI (for recipe translation and adaptation)
OPENAI_API_KEY=

# Resend (for all outgoing email; required for verification + shopping list emails)
# Production (myrecipes.cloud): set RESEND_API_KEY, RESEND_FROM_EMAIL, FRONTEND_URL=https://myrecipes.cloud
RESEND_API_KEY=
RESEND_FROM_EMAIL=
# Frontend base URL (for verification emails). Local dev: http://localhost:5173 | Production: https://myrecipes.cloud
FRONTEND_URL=http://localhost:5173

# Admin token for privileged operations
ADMIN_TOKEN=

# Turnstile: omit to use test keys (widget visible, validation passes, no bot protection).
# For production (myrecipes.cloud): set VITE_TURNSTILE_SITE_KEY (frontend) and TURNSTILE_SECRET_KEY (backend).
TURNSTILE_SECRET_KEY=

# CORS: comma-separated origins, or leave unset for * (dev). Production: https://myrecipes.cloud
# CORS_ORIGINS=https://myrecipes.cloud

# --- Production (myrecipes.cloud) ---
# Backend: set FRONTEND_URL=https://myrecipes.cloud, CORS_ORIGINS=https://myrecipes.cloud, and Resend vars above.
# Frontend: set VITE_API_URL=https://api.myrecipes.cloud in frontend/.env when building for production.
